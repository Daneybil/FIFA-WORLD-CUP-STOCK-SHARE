rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper to check if document belongs to the logged-in user
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for Portfolios collection
    match /portfolios/{portfolioId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for Holdings collection
    match /holdings/{holdingId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for Payments collection
    match /payments/{paymentId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write, delete: if isAuth() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
  }
}
